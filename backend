<script>
'use strict';
const API = '?api=1';
const state = { tasks:[], stats:{}, activeView:'all', catFilter:'All', statusFilter:'all', priorityFilter:null, searchQuery:'', editId:null };
const today = new Date().toISOString().split('T')[0];
const $  = id => document.getElementById(id);
const esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

async function api(method, params={}, body=null) {
  const url = new URL(API, location.href);
  Object.entries(params).forEach(([k,v]) => url.searchParams.set(k,v));
  const opts = { method, headers:{'Content-Type':'application/json'} };
  if (body) opts.body = JSON.stringify(body);
  const res  = await fetch(url, opts);
  const data = await res.json();
  if (!res.ok) throw new Error(data.error || 'Request failed');
  return data;
}

async function loadTasks() {
  const params = {};
  if (state.priorityFilter)         params.priority = state.priorityFilter;
  if (state.catFilter !== 'All')    params.category = state.catFilter;
  if (state.statusFilter !== 'all') params.status   = state.statusFilter;
  if (state.activeView !== 'all')   params.view     = state.activeView;
  if (state.searchQuery)            params.q        = state.searchQuery;
  try {
    const data  = await api('GET', params);
    state.tasks = data.tasks; state.stats = data.stats;
    renderTasks(); renderStats(); renderDeadlines();
  } catch(e) { $('task-list').innerHTML = `<p class="empty">Error: ${e.message}</p>`; }
}

function isOverdue(t) { return t.status !== 'done' && t.due_date && t.due_date < today; }
function fmtDate(d) { const [y,m,day]=d.split('-'); return new Date(+y,+m-1,+day).toLocaleDateString('en-IN',{day:'numeric',month:'short'}); }
const priClass = { High:'badge-high', Medium:'badge-med', Low:'badge-low' };

function renderTasks() {
  if (!state.tasks.length) { $('task-list').innerHTML='<div class="empty">📋 No tasks found</div>'; return; }
  $('task-list').innerHTML = state.tasks.map(t => `
    <div class="task-card ${t.status==='done'?'done-card':''}">
      <div class="check-circle ${t.status==='done'?'checked':''}" data-id="${t.id}"></div>
      <div class="task-body">
        <div class="task-title">${esc(t.title)}</div>
        <div class="task-meta">
          <span class="badge ${t.status==='done'?'badge-done':priClass[t.priority]}">${t.status==='done'?'Done':t.priority}</span>
          <span class="badge badge-cat">${t.category}</span>
          ${t.due_date?`<span class="due-date ${isOverdue(t)?'overdue':''}">⏱ ${isOverdue(t)?'Overdue: ':''}${fmtDate(t.due_date)}</span>`:''}
        </div>
        ${t.description?`<div class="task-desc">${esc(t.description)}</div>`:''}
      </div>
      <div class="task-actions">
        <button class="action-btn edit-btn" data-id="${t.id}">✎</button>
        <button class="action-btn del-btn"  data-id="${t.id}">✕</button>
      </div>
    </div>`).join('');
}

function renderStats() {
  const {total,done,active,overdue} = state.stats;
  const pct = total ? Math.round(done/total*100) : 0;
  $('s-total').textContent=total; $('s-done').textContent=done;
  $('s-active').textContent=active; $('s-overdue').textContent=overdue;
  $('s-pct').textContent=pct+'% done';
  $('prog-label').textContent=`${done} of ${total} complete`;
  $('prog-fill').style.width=pct+'%';
  $('badge-active').textContent=active;
}

function renderDeadlines() {
  const upcoming = state.tasks.filter(t=>t.status!=='done'&&t.due_date&&t.due_date>=today).sort((a,b)=>a.due_date.localeCompare(b.due_date)).slice(0,4);
  const colors = {High:'#C0392B',Medium:'#D4AC0D',Low:'#2980B9'};
  const dl = $('deadline-list');
  if (!upcoming.length) { dl.innerHTML='<p style="font-size:13px;color:var(--muted)">No upcoming deadlines.</p>'; return; }
  dl.innerHTML = upcoming.map(t => {
    const d = new Date(t.due_date+'T00:00:00');
    const diff = Math.ceil((d - new Date(today+'T00:00:00'))/86400000);
    const when = diff===0?'Today':diff===1?'Tomorrow':`In ${diff} days`;
    return `<div class="deadline-item"><div class="deadline-dot" style="background:${colors[t.priority]}"></div><div><div class="dl-title">${esc(t.title)}</div><div style="font-size:12px;color:var(--muted)">${t.category}</div></div><div class="dl-time">${when}</div></div>`;
  }).join('');
}

function openModal(task=null) {
  state.editId = task ? task.id : null;
  $('modal-title').textContent = task ? 'Edit Task' : 'New Task';
  $('f-title').value    = task?.title       ?? '';
  $('f-desc').value     = task?.description ?? '';
  $('f-priority').value = task?.priority    ?? 'Medium';
  $('f-cat').value      = task?.category    ?? 'Work';
  $('f-date').value     = task?.due_date    ?? '';
  $('modal-overlay').classList.add('open');
  setTimeout(()=>$('f-title').focus(),80);
}

function closeModal() { $('modal-overlay').classList.remove('open'); }

async function saveTask() {
  const title = $('f-title').value.trim();
  if (!title) { $('f-title').focus(); return; }
  const body = { title, description:$('f-desc').value.trim(), priority:$('f-priority').value, category:$('f-cat').value, due_date:$('f-date').value||null };
  try {
    if (state.editId) {
      body.status = state.tasks.find(t=>t.id===state.editId)?.status ?? 'active';
      await api('PUT',{id:state.editId},body); toast('Task updated');
    } else {
      await api('POST',{},body); toast('Task created');
    }
    closeModal(); loadTasks();
  } catch(e) { toast(e.message, true); }
}

async function toggleDone(id) { try { await api('PATCH',{id}); loadTasks(); } catch(e) { toast(e.message,true); } }
async function deleteTask(id) {
  if (!confirm('Delete this task?')) return;
  try { await api('DELETE',{id}); toast('Task deleted'); loadTasks(); } catch(e) { toast(e.message,true); }
}

function toast(msg, isError=false) {
  const el = $('toast');
  el.textContent = msg;
  el.style.background = isError ? '#C0392B' : '#1A1814';
  el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'), 2500);
}

// Event delegation
$('task-list').addEventListener('click', e => {
  const chk  = e.target.closest('.check-circle');
  const edit = e.target.closest('.edit-btn');
  const del  = e.target.closest('.del-btn');
  if (chk)  { toggleDone(+chk.dataset.id); return; }
  if (del)  { deleteTask(+del.dataset.id); return; }
  if (edit) { const t=state.tasks.find(t=>t.id===+edit.dataset.id); if(t) openModal(t); }
});

document.querySelectorAll('.nav-item[data-view]').forEach(el => {
  el.addEventListener('click', () => {
    state.activeView='all'; state.activeView=el.dataset.view; state.priorityFilter=null;
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active')); el.classList.add('active');
    const labels={all:'All Tasks',today:"Today's Tasks",upcoming:'Upcoming',done:'Completed'};
    $('section-label').textContent = labels[el.dataset.view]||'Tasks';
    loadTasks();
  });
});

document.querySelectorAll('.nav-item[data-priority]').forEach(el => {
  el.addEventListener('click', () => {
    state.priorityFilter=el.dataset.priority; state.activeView='all';
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active')); el.classList.add('active');
    $('section-label').textContent=el.dataset.priority+' Priority'; loadTasks();
  });
});

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    state.catFilter=btn.dataset.cat;
    document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active')); btn.classList.add('active');
    loadTasks();
  });
});

document.querySelectorAll('.tab').forEach(tab => {
  tab.addEventListener('click', () => {
    state.statusFilter=tab.dataset.status;
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active')); tab.classList.add('active');
    loadTasks();
  });
});

let st;
$('search-input').addEventListener('input', () => {
  clearTimeout(st); st=setTimeout(()=>{ state.searchQuery=$('search-input').value.trim(); loadTasks(); },300);
});

$('open-modal').addEventListener('click',  ()=>openModal());
$('close-modal').addEventListener('click', closeModal);
$('cancel-modal').addEventListener('click',closeModal);
$('save-task').addEventListener('click',   saveTask);
$('modal-overlay').addEventListener('click', e=>{ if(e.target===$('modal-overlay')) closeModal(); });
document.addEventListener('keydown', e=>{ if(e.key==='Escape') closeModal(); });

loadTasks();
</script>
</body>
