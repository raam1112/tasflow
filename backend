//  TaskFlow - Complete Single File Full Stack App
//  PHP + MySQL | All-in-one: Auth + API + Dashboard
// ============================================================

// ── CONFIG ───────────────────────────────────────────────────
define('DB_HOST', 'your_host_here');        // e.g. sql123.infinityfree.net
define('DB_NAME', 'your_database_here');    // e.g. if0_12345678_taskflow
define('DB_USER', 'your_username_here');    // e.g. if0_12345678
define('DB_PASS', 'your_password_here');    // your database password

// ── DATABASE ─────────────────────────────────────────────────
function getDB(): PDO {
    static $pdo = null;
    if ($pdo === null) {
        $dsn = 'mysql:host=' . DB_HOST . ';dbname=' . DB_NAME . ';charset=utf8mb4';
        $pdo = new PDO($dsn, DB_USER, DB_PASS, [
            PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
            PDO::ATTR_EMULATE_PREPARES   => false,
        ]);
    }
    return $pdo;
}

// ── AUTO SETUP: Create tables if they don't exist ────────────
function setupDB(): void {
    $db = getDB();
    $db->exec("
        CREATE TABLE IF NOT EXISTS tf_users (
            id         INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
            name       VARCHAR(100)  NOT NULL,
            email      VARCHAR(150)  NOT NULL UNIQUE,
            password   VARCHAR(255)  NOT NULL,
            avatar     VARCHAR(10)   DEFAULT NULL,
            created_at DATETIME      DEFAULT CURRENT_TIMESTAMP
        ) ENGINE=InnoDB;

        CREATE TABLE IF NOT EXISTS tf_tasks (
            id          INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
            user_id     INT UNSIGNED NOT NULL,
            title       VARCHAR(255) NOT NULL,
            description TEXT         DEFAULT NULL,
            priority    ENUM('High','Medium','Low') NOT NULL DEFAULT 'Medium',
            category    ENUM('Work','Personal','Study','Health') NOT NULL DEFAULT 'Work',
            status      ENUM('active','done') NOT NULL DEFAULT 'active',
            due_date    DATE         DEFAULT NULL,
            created_at  DATETIME     DEFAULT CURRENT_TIMESTAMP,
            updated_at  DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
            CONSTRAINT fk_tf_tasks_user FOREIGN KEY (user_id)
                REFERENCES tf_users(id) ON DELETE CASCADE
        ) ENGINE=InnoDB;
    ");
}

// ── SESSION ──────────────────────────────────────────────────
if (session_status() === PHP_SESSION_NONE) {
    session_set_cookie_params(['lifetime'=>0,'path'=>'/','httponly'=>true,'samesite'=>'Strict']);
    session_start();
}

function isLoggedIn(): bool   { return !empty($_SESSION['user_id']); }
function currentUserId(): int { return (int)($_SESSION['user_id'] ?? 0); }
function currentUserName(): string   { return $_SESSION['user_name']   ?? 'User'; }
function currentUserAvatar(): string { return $_SESSION['user_avatar'] ?? '?'; }

function loginUser(array $user): void {
    session_regenerate_id(true);
    $_SESSION['user_id']     = $user['id'];
    $_SESSION['user_name']   = $user['name'];
    $_SESSION['user_email']  = $user['email'];
    $_SESSION['user_avatar'] = $user['avatar'];
}

function logoutUser(): void {
    session_unset(); session_destroy();
    header('Location: ' . $_SERVER['PHP_SELF']); exit;
}

function csrfToken(): string {
    if (empty($_SESSION['csrf_token']))
        $_SESSION['csrf_token'] = bin2hex(random_bytes(32));
    return $_SESSION['csrf_token'];
}

function verifyCsrf(string $t): bool {
    return hash_equals($_SESSION['csrf_token'] ?? '', $t);
}

function h(string $s): string {
    return htmlspecialchars($s, ENT_QUOTES|ENT_HTML5, 'UTF-8');
}

// ── HELPERS ──────────────────────────────────────────────────
function sanitizePriority(string $v): string {
    return in_array($v,['High','Medium','Low']) ? $v : 'Medium';
}
function sanitizeCategory(string $v): string {
    return in_array($v,['Work','Personal','Study','Health']) ? $v : 'Work';
}
function sanitizeStatus(string $v): string {
    return in_array($v,['active','done']) ? $v : 'active';
}

function jsonResponse(mixed $data, int $code = 200): never {
    http_response_code($code);
    header('Content-Type: application/json');
    echo json_encode($data);
    exit;
}

// ── INIT DB ──────────────────────────────────────────────────
try { setupDB(); }
catch (PDOException $e) {
    die('<div style="font-family:sans-serif;padding:40px;color:#c00">
        <h2>Database Connection Failed</h2>
        <p>Please update the DB_HOST, DB_NAME, DB_USER and DB_PASS values at the top of this file.</p>
        <code>' . h($e->getMessage()) . '</code>
    </div>');
}

// ── ROUTE: API ────────────────────────────────────────────────
if (isset($_GET['api'])) {
    if (!isLoggedIn()) jsonResponse(['error'=>'Unauthorized'], 401);

    $uid    = currentUserId();
    $db     = getDB();
    $method = $_SERVER['REQUEST_METHOD'];
    $taskId = isset($_GET['id']) ? (int)$_GET['id'] : null;
    $today  = date('Y-m-d');

    function ownTask(PDO $db, int $id, int $uid): ?array {
        $s = $db->prepare('SELECT * FROM tf_tasks WHERE id=? AND user_id=?');
        $s->execute([$id, $uid]);
        return $s->fetch() ?: null;
    }

    function jsonBody(): array {
        return json_decode(file_get_contents('php://input'), true) ?? [];
    }

    // GET – list tasks + stats
    if ($method === 'GET') {
        $where  = ['t.user_id = :uid'];
        $params = [':uid' => $uid];

        if (!empty($_GET['status']) && $_GET['status'] !== 'all') {
            $where[] = 't.status = :status';
            $params[':status'] = sanitizeStatus($_GET['status']);
        }
        if (!empty($_GET['priority'])) {
            $where[] = 't.priority = :priority';
            $params[':priority'] = sanitizePriority($_GET['priority']);
        }
        if (!empty($_GET['category'])) {
            $where[] = 't.category = :category';
            $params[':category'] = sanitizeCategory($_GET['category']);
        }
        if (!empty($_GET['view'])) {
            switch ($_GET['view']) {
                case 'today':
                    $where[] = 't.due_date = :today'; $params[':today'] = $today; break;
                case 'upcoming':
                    $where[] = 't.due_date > :today AND t.status = "active"'; $params[':today'] = $today; break;
                case 'done':
                    $where[] = 't.status = "done"'; break;
            }
        }
        if (!empty($_GET['q'])) {
            $where[] = '(t.title LIKE :q OR t.description LIKE :q)';
            $params[':q'] = '%' . $_GET['q'] . '%';
        }

        $sql  = 'SELECT t.* FROM tf_tasks t WHERE ' . implode(' AND ', $where)
              . ' ORDER BY FIELD(t.priority,"High","Medium","Low"), t.due_date ASC';
        $stmt = $db->prepare($sql); $stmt->execute($params);
        $tasks = $stmt->fetchAll();

        $sStat = $db->prepare('SELECT status, COUNT(*) n FROM tf_tasks WHERE user_id=? GROUP BY status');
        $sStat->execute([$uid]);
        $stats = ['total'=>0,'done'=>0,'active'=>0,'overdue'=>0];
        foreach ($sStat->fetchAll() as $r) {
            $stats['total'] += $r['n'];
            if ($r['status']==='done')   $stats['done']   = (int)$r['n'];
            if ($r['status']==='active') $stats['active'] = (int)$r['n'];
        }
        $sOver = $db->prepare("SELECT COUNT(*) FROM tf_tasks WHERE user_id=? AND status='active' AND due_date < ?");
        $sOver->execute([$uid, $today]);
        $stats['overdue'] = (int)$sOver->fetchColumn();

        jsonResponse(['tasks'=>$tasks,'stats'=>$stats]);
    }

    // POST – create
    if ($method === 'POST') {
        $d = jsonBody(); $title = trim($d['title'] ?? '');
        if (!$title) jsonResponse(['error'=>'Title required'], 422);
        $stmt = $db->prepare('INSERT INTO tf_tasks (user_id,title,description,priority,category,status,due_date) VALUES (?,?,?,?,?,?,?)');
        $stmt->execute([$uid, $title, trim($d['description']??''), sanitizePriority($d['priority']??'Medium'), sanitizeCategory($d['category']??'Work'), 'active', $d['due_date']??null]);
        $row = $db->prepare('SELECT * FROM tf_tasks WHERE id=?'); $row->execute([$db->lastInsertId()]);
        jsonResponse(['task'=>$row->fetch()], 201);
    }

    // PUT – update
    if ($method === 'PUT') {
        if (!$taskId || !ownTask($db,$taskId,$uid)) jsonResponse(['error'=>'Not found'],404);
        $d = jsonBody(); $title = trim($d['title']??'');
        if (!$title) jsonResponse(['error'=>'Title required'],422);
        $db->prepare('UPDATE tf_tasks SET title=?,description=?,priority=?,category=?,status=?,due_date=? WHERE id=? AND user_id=?')
           ->execute([$title,trim($d['description']??''),sanitizePriority($d['priority']??'Medium'),sanitizeCategory($d['category']??'Work'),sanitizeStatus($d['status']??'active'),$d['due_date']??null,$taskId,$uid]);
        $row = $db->prepare('SELECT * FROM tf_tasks WHERE id=?'); $row->execute([$taskId]);
        jsonResponse(['task'=>$row->fetch()]);
    }

    // PATCH – toggle
    if ($method === 'PATCH') {
        $task = $taskId ? ownTask($db,$taskId,$uid) : null;
        if (!$task) jsonResponse(['error'=>'Not found'],404);
        $newStatus = $task['status']==='done' ? 'active' : 'done';
        $db->prepare('UPDATE tf_tasks SET status=? WHERE id=?')->execute([$newStatus,$taskId]);
        jsonResponse(['status'=>$newStatus]);
    }

    // DELETE
    if ($method === 'DELETE') {
        if (!$taskId || !ownTask($db,$taskId,$uid)) jsonResponse(['error'=>'Not found'],404);
        $db->prepare('DELETE FROM tf_tasks WHERE id=? AND user_id=?')->execute([$taskId,$uid]);
        jsonResponse(['deleted'=>true]);
    }

    jsonResponse(['error'=>'Method not allowed'],405);
}

// ── ROUTE: LOGOUT ─────────────────────────────────────────────
if (isset($_GET['logout'])) { logoutUser(); }

// ── ROUTE: REGISTER ───────────────────────────────────────────
$page   = $_GET['page'] ?? 'dashboard';
$error  = '';
$success= '';

if ($page === 'register') {
    if ($_SERVER['REQUEST_METHOD']==='POST') {
        if (!verifyCsrf($_POST['csrf_token']??'')) {
            $error = 'Invalid request.';
        } else {
            $name     = trim($_POST['name']    ?? '');
            $email    = trim($_POST['email']   ?? '');
            $password = trim($_POST['password']?? '');
            $confirm  = trim($_POST['confirm'] ?? '');
            if (!$name||!$email||!$password) {
                $error = 'All fields are required.';
            } elseif (!filter_var($email,FILTER_VALIDATE_EMAIL)) {
                $error = 'Invalid email address.';
            } elseif (strlen($password)<8) {
                $error = 'Password must be at least 8 characters.';
            } elseif ($password!==$confirm) {
                $error = 'Passwords do not match.';
            } else {
                $db   = getDB();
                $stmt = $db->prepare('SELECT id FROM tf_users WHERE email=?');
                $stmt->execute([$email]);
                if ($stmt->fetch()) {
                    $error = 'Email already registered.';
                } else {
                    $hash   = password_hash($password, PASSWORD_BCRYPT, ['cost'=>12]);
                    $words  = explode(' ',$name);
                    $avatar = strtoupper(substr($words[0],0,1).(isset($words[1])?substr($words[1],0,1):''));
                    $db->prepare('INSERT INTO tf_users (name,email,password,avatar) VALUES (?,?,?,?)')->execute([$name,$email,$hash,$avatar]);
                    $success = 'Account created! <a href="?page=login">Log in now →</a>';
                }
            }
        }
    }
}

// ── ROUTE: LOGIN ──────────────────────────────────────────────
if ($page === 'login') {
    if ($_SERVER['REQUEST_METHOD']==='POST') {
        if (!verifyCsrf($_POST['csrf_token']??'')) {
            $error = 'Invalid request.';
        } else {
            $email    = trim($_POST['email']   ?? '');
            $password = trim($_POST['password']?? '');
            if (!$email||!$password) {
                $error = 'Please enter your email and password.';
            } else {
                $db   = getDB();
                $stmt = $db->prepare('SELECT * FROM tf_users WHERE email=? LIMIT 1');
                $stmt->execute([$email]);
                $user = $stmt->fetch();
                if ($user && password_verify($password,$user['password'])) {
                    loginUser($user);
                    header('Location: ' . $_SERVER['PHP_SELF']); exit;
                } else {
                    $error = 'Incorrect email or password.';
                }
            }
        }
    }
}

// ── REDIRECT if not logged in ─────────────────────────────────
if (!isLoggedIn() && !in_array($page,['login','register'])) {
    header('Location: ?page=login'); exit;
}
if (isLoggedIn() && in_array($page,['login','register'])) {
    header('Location: ' . $_SERVER['PHP_SELF']); exit;
}

$name   = isLoggedIn() ? h(currentUserName())   : '';
$avatar = isLoggedIn() ? h(currentUserAvatar()) : '';
?>
